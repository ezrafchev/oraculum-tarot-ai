# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
next-env.d.ts
*.tsbuildinfo
/dist/
/dist-pages/
/.wrangler/
/.sites-runtime/
/outputs/
/work/

# secrets and credentials
*.key
*.p12
*.pfx
*.token
secrets.*

# editor and temporary files
.idea/
.vscode/
*.swp
*.swo
*.tmp
*.cache
