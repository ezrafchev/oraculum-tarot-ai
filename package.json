{
  "name": "oraculum-ai",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "build": "bash scripts/build-verified.sh",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "build:pages": "bash scripts/sites-env.sh -- vite build --config vite.pages.config.ts",
    "preview:pages": "bash scripts/sites-env.sh -- vite preview --config vite.pages.config.ts",
    "typecheck": "bash scripts/sites-env.sh -- tsc --noEmit",
    "test": "bash scripts/sites-env.sh -- vitest run",
    "test:watch": "bash scripts/sites-env.sh -- vitest",
    "test:rendered": "npm run build && node --test tests/rendered-html.test.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build:pages",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern dist-pages --ignore-pattern .next --ignore-pattern coverage"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.84",
    "framer-motion": "^12.42.2",
    "idb": "^8.0.3",
    "lucide-react": "^1.26.0",
    "next": "16.2.11",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.46.0",
    "@cloudflare/workers-types": "5.20260723.1",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.11",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "4.113.0"
  },
  "overrides": {
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  },
  "type": "module",
  "displayName": "ORACULUM AI"
}
